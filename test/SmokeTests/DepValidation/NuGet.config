<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="local-packages" value="./local-packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!--
    Package source mapping ensures that the SDK packages under test are ONLY
    resolved from the local-packages feed. This prevents NuGet from silently
    falling back to nuget.org and pulling an older published version when the
    local feed is missing the expected package.
  -->
  <packageSourceMapping>
    <packageSource key="local-packages">
      <package pattern="Microsoft.DurableTask.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
