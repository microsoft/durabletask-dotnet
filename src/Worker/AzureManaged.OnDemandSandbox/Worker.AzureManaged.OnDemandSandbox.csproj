<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net6.0;net8.0;net10.0</TargetFrameworks>
    <PackageDescription>Azure Managed on-demand sandbox activity worker extensions for the Durable Task Framework worker.</PackageDescription>
    <AssemblyName>Microsoft.DurableTask.Worker.AzureManaged.OnDemandSandbox</AssemblyName>
    <RootNamespace>Microsoft.DurableTask</RootNamespace>
    <EnableStyleCop>true</EnableStyleCop>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" />
    <PackageReference Include="Grpc.Net.Client" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AzureManaged\Worker.AzureManaged.csproj" />
    <ProjectReference Include="..\Grpc\Worker.Grpc.csproj" />
    <ProjectReference Include="..\..\Grpc\Grpc.csproj" />
  </ItemGroup>

  <ItemGroup>
    <SharedSection Include="AzureManaged.OnDemandSandbox" />
    <SharedSection Include="Core" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.DurableTask.Worker.AzureManaged.Tests" Key="$(StrongNamePublicKey)" />
  </ItemGroup>

</Project>
