<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net6.0;net8.0;net10.0</TargetFrameworks>
    <PackageDescription>Plugin system for Microsoft Durable Task SDK. Includes built-in plugins for logging, metrics, authorization, validation, and rate limiting.</PackageDescription>
    <AssemblyName>Microsoft.DurableTask.Extensions.Plugins</AssemblyName>
    <RootNamespace>Microsoft.DurableTask</RootNamespace>
    <EnableStyleCop>true</EnableStyleCop>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Abstractions\Abstractions.csproj" />
    <ProjectReference Include="..\..\Client\Core\Client.csproj" />
    <ProjectReference Include="..\..\Worker\Core\Worker.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Do NOT include SharedSection Core here. The Plugins project has IVT from Abstractions,
      and Abstractions (netstandard2.0) ships polyfill types (NullableAttributes, CSharpLangCompat)
      that clash with their real counterparts when the Plugins project targets net6.0+.
      Instead, the minimal Check utilities needed are included directly.
    -->
  </ItemGroup>

</Project>
